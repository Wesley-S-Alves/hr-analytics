# ═══════════════════════════════════════════════════════════════
# LLM — Google Gemini
# ═══════════════════════════════════════════════════════════════
GEMINI_API_KEY=sua_chave_aqui

# Parâmetros do batch processor (async + semaphore)
LLM_ITEMS_PER_REQUEST=10
LLM_CONCURRENCY=10
LLM_TIMEOUT=120
LLM_MAX_RETRIES=5

# ═══════════════════════════════════════════════════════════════
# MLflow — tracking de experimentos + traces de GenAI
# ═══════════════════════════════════════════════════════════════
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=hr-attrition
# Experimento dedicado para traces de LangChain + Gemini (autolog)
MLFLOW_GENAI_EXPERIMENT=hr-genai-traces
# URL mostrada como botão "Abrir MLflow" na tela Monitoramento
MLFLOW_UI_URL=http://localhost:5000

# ═══════════════════════════════════════════════════════════════
# Banco de dados (SQLite por padrão; use PostgreSQL em produção)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=sqlite:///data/hr_analytics.db

# ═══════════════════════════════════════════════════════════════
# Treino — reprodutibilidade e tuning
# ═══════════════════════════════════════════════════════════════
RANDOM_SEED=42
OPTUNA_N_TRIALS=50
CV_FOLDS=5
TEST_SIZE=0.2

# Thresholds de classificação de risco (probabilidade de attrition)
RISK_THRESHOLD_LOW=0.2
RISK_THRESHOLD_MEDIUM=0.4
RISK_THRESHOLD_HIGH=0.7

# ═══════════════════════════════════════════════════════════════
# API — host, porta e CORS
# ═══════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8000
# Origens permitidas (CORS). Em produção, restringir ao domínio real.
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ═══════════════════════════════════════════════════════════════
# Logging estruturado
# ═══════════════════════════════════════════════════════════════
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_FORMAT: text (dev) | json (produção / ingestão em Datadog/CloudWatch/Loki)
LOG_FORMAT=text

# ═══════════════════════════════════════════════════════════════
# Alertas de drift (opcional)
# ═══════════════════════════════════════════════════════════════
# Webhook Slack Incoming, Discord, Teams (via bridge) ou endpoint próprio.
# Se vazio, notificações ficam desabilitadas.
DRIFT_WEBHOOK_URL=
